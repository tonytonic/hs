          "src": "02-compteur-annuel.png",
          "sizes": "834x1386",
          "type": "image/png",
          "label": "Widget Preview"
        }
      ]
    }
  ],
  "share_target": {
    "action": "https://tonytonic.github.io/hs/menu.html",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "https://tonytonic.github.io/hs/menu.html",
